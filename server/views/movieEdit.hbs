{{> header}}
{{> menu}}
<main>
    <h1>{{titolPagina}}</h1>
    <div class="card">
        <form action="/editarPeli" method="POST" style="margin-bottom: 30px;">
            <input type="hidden" name="film_id" value="{{movie.film_id}}">

            <label>Títol:</label><br>
            <input type="text" name="title" value="{{movie.title}}" required style="width:100%; margin-bottom:10px;"><br>

            <label>Descripció:</label><br>
            <textarea name="description" rows="4" style="width:100%; margin-bottom:10px;">{{movie.description}}</textarea><br>

            <label>Any:</label><br>
            <input type="number" name="release_year" value="{{movie.release_year}}" required style="width:100%; margin-bottom:10px;"><br>

            <label>Idioma:</label><br>
            <select name="language_id" style="width:100%; margin-bottom:20px;">
                {{#each languages}}
                    <option value="{{language_id}}">{{name}}</option>
                {{/each}}
            </select><br>

            <button type="submit" class="btn-primary">Actualitzar Dades</button>
        </form>

        <hr style="border:1px solid rgba(255,255,255,0.1); margin: 20px 0;">

        <form action="/esborrarPeli" method="POST" onsubmit="return confirm('N'estàs segur que vols esborrar aquesta pel·lícula?');">
            <input type="hidden" name="film_id" value="{{movie.film_id}}">
            <button type="submit" class="btn-info" style="background: red; color: white;">🗑️ Esborrar Pel·lícula</button>
        </form>
    </div>
</main>
{{> footer}}