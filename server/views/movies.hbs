{{> header}}
{{> menu}}
<h1>Catàleg de Pel·lícules</h1>

<div class="movies-grid">
  {{#each movies}}
    <div class="movie-card">
      <h2>{{this.title}}</h2>
      
      <div class="movie-info">
        <span>📅 {{this.release_year}}</span> | 
        <span>⭐ {{this.rating}}</span>
      </div>

      <p class="movie-description">{{this.description}}</p>
      
      <div class="actors-list">
        <strong>Actors principals:</strong>
        <span class="actors-names">{{this.actors}}</span>
      </div>
    </div>
  {{/each}}
</div>


{{> footer}}